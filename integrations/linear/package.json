{
  "name": "pi-linear",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,ui \"tsx watch src/server/index.ts\" \"vite dev\"",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "vite build && tsup",
    "build:server": "tsup",
    "build:ui": "vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "@linear/sdk": "^77.0.0",
    "@mariozechner/pi-ai": "0.63.1",
    "@mariozechner/pi-coding-agent": "0.63.1",
    "@sinclair/typebox": "^0.34.0",
    "better-sqlite3": "^12.6.2",
    "hono": "^4.7.11",
    "varlock": "^0.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aliou/biome-plugins": "^0.4.0",
    "@biomejs/biome": "^2.0.0",
    "@mariozechner/pi-agent-core": "0.63.1"
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.7.0",
    "vite": "^7.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
