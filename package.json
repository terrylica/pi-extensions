{
  "name": "@aliou/pi-harness",
  "private": true,
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aliou/pi-harness"
  },
  "pi": {
    "extensions": [
      "./extensions",
      "extensions/*/index.ts"
    ]
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:native": "./scripts/build-native-tools.sh",
    "postinstall": "./scripts/build-native-tools.sh"
  },
  "dependencies": {
    "@aliou/pi-linkup": "^0.7.1",
    "@aliou/pi-utils-settings": "^0.11.2",
    "@aliou/pi-utils-ui": "^0.1.4",
    "@aliou/sesame": "^0.4.0",
    "@aliou/sh": "^0.1.0",
    "better-sqlite3": "^12.6.2",
    "diff": ">=8.0.0",
    "xxhash-wasm": "^1.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@aliou/biome-plugins": "^0.4.0",
    "@biomejs/biome": "^2.0.0",
    "@mariozechner/pi-agent-core": "0.67.4",
    "@mariozechner/pi-ai": "0.67.4",
    "@mariozechner/pi-coding-agent": "0.67.4",
    "@mariozechner/pi-tui": "0.67.4",
    "@sinclair/typebox": "^0.34.41",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "@mariozechner/pi-coding-agent": "0.67.4",
      "@mariozechner/pi-agent-core": "$@mariozechner/pi-coding-agent",
      "@mariozechner/pi-ai": "$@mariozechner/pi-coding-agent",
      "@mariozechner/pi-tui": "$@mariozechner/pi-coding-agent"
    },
    "onlyBuiltDependencies": [
      "@aliou/sh",
      "better-sqlite3"
    ]
  },
  "packageManager": "pnpm@10.26.1"
}
