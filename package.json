{
  "name": "@aliou/pi-extensions",
  "private": true,
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./extensions/*"
    ]
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm changeset publish"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.27.11",
    "@mariozechner/pi-agent-core": "0.49.2",
    "@mariozechner/pi-ai": "0.49.2",
    "@mariozechner/pi-coding-agent": "0.49.2",
    "@mariozechner/pi-tui": "0.49.2",
    "@sinclair/typebox": "^0.34.41",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "@mariozechner/pi-agent-core": "$@mariozechner/pi-coding-agent",
      "@mariozechner/pi-ai": "$@mariozechner/pi-coding-agent",
      "@mariozechner/pi-tui": "$@mariozechner/pi-coding-agent"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "packageManager": "pnpm@10.26.1"
}
